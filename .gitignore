# ============================================================
# zsh-snap-man — .gitignore
# crisis1er — https://github.com/crisis1er
# ============================================================

# ------------------------------
# Editor temporary files
# ------------------------------
*.swp
*.swo
*~
.idea/
.vscode/

# ------------------------------
# macOS artifacts
# ------------------------------
.DS_Store

# ------------------------------
# Backup and patch artifacts
# ------------------------------
*.bak
*.bak.*
*.orig
*.rej

# ------------------------------
# Log files
# (may contain private IPs, DNS queries, URLs)
# ------------------------------
*.log

# ------------------------------
# Environment and secrets
# (IPs, credentials, tokens — never commit)
# ------------------------------
.env
.env.*
secrets.*
